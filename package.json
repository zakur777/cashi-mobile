{
  "name": "cashi-mobile",
  "version": "1.0.0",
  "description": "Cashi Mobile app scaffold with Expo Router and testing.",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest/setup.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/android/",
      "/ios/"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.2",
    "expo": "^55.0.23",
    "expo-router": "^55.0.14",
    "react": "^19.2.6",
    "react-native": "^0.85.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "^19.2.14",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.17",
    "jest-util": "^30.4.1",
    "typescript": "^5.9.3"
  }
}
